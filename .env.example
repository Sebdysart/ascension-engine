# Ascension Engine — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Vision tagging uses the authenticated `claude` CLI — no API key needed.
# The tagger calls `claude -p ... --allowedTools Read` which uses your
# existing Claude Code authentication automatically.

# Optional: override which Claude model alias the vision tagger uses.
# Accepts any alias the `claude` CLI understands (e.g. haiku, sonnet, opus).
# Default: haiku (fast and cheap for image tagging)
# VISION_MODEL=haiku
